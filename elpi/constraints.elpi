% -----------------------------------------------------------------------------
% Constaints data
% -----------------------------------------------------------------------------

accumulate "Trocq.Elpi/data".
accumulate "Trocq.Elpi/aterm".

kind cstr type.

typeabbrev cstr-list (list cstr).

% D_π(C, C_A, C_B)
type cstr-pi param-class -> param-class -> param-class -> cstr.

% D_->(C, C_A, C_B)
type cstr-arrow param-class -> param-class -> param-class -> cstr.

% D_□(C, C_R)
type cstr-type param-class -> param-class -> cstr.

% G @ AT ~ T' ∵ RT
type cstr-gref gref -> aterm -> term -> term -> cstr.

% C >= C'
type cstr-geq param-class -> param-class -> cstr.

% C = C'
type cstr-eq param-class -> param-class -> cstr.

namespace map-class-cstr {

    pred all -> map-class.
    all map0.
    all map1.
    all map2a.
    all map2b.
    all map3.
    all map4.

    pred geq -> map-class, map-class.
    geq map0  map0.
    geq map1  M :- std.mem [map0, map1] M.
    geq map2a M :- std.mem [map0, map1, map2a] M.
    geq map2b M :- std.mem [map0, map1, map2b] M.
    geq map3  M :- std.mem [map0, map1, map2a, map2b, map3] M.
    geq map4  M :- all M.

    func dep-pi map-class -> param-class, param-class.
    dep-pi map0  (pc map0 map0)  (pc map0 map0).
    dep-pi map1  (pc map0 map2a) (pc map1 map0).
    dep-pi map2a (pc map0 map4)  (pc map2a map0).
    dep-pi map2b (pc map0 map2a) (pc map2b map0).
    dep-pi map3  (pc map0 map4)  (pc map3 map0).
    dep-pi map4  (pc map0 map4)  (pc map4 map0).

    % minimal dependencies to translate an arrow type, see the table in the article
    func dep-arrow map-class -> param-class, param-class.
    dep-arrow map0  (pc map0 map0)  (pc map0 map0).
    dep-arrow map1  (pc map0 map1)  (pc map1 map0).
    dep-arrow map2a (pc map0 map2b) (pc map2a map0).
    dep-arrow map2b (pc map0 map2a) (pc map2b map0).
    dep-arrow map3  (pc map0 map3)  (pc map3 map0).
    dep-arrow map4  (pc map0 map4)  (pc map4 map0).
}

namespace param-class-cstr {

    func negate param-class -> param-class.
    negate (pc M N) (pc N M).

    pred geq -> param-class, param-class.
    geq (pc M1 N1) (pc M2 N2) :-
        map-class-cstr.geq M1 M2,
        map-class-cstr.geq N1 N2.

    func dep-pi param-class -> param-class, param-class.
    dep-pi (pc M N) ClassA ClassB :-
        map-class-cstr.dep-pi M ClassAM ClassBM,
        map-class-cstr.dep-pi N ClassAN ClassBN,
        param-class.union ClassAM {param-class-cstr.negate ClassAN} ClassA,
        param-class.union ClassBM {param-class-cstr.negate ClassBN} ClassB.

    func dep-arrow param-class -> param-class, param-class.
    dep-arrow (pc M N) ClassA ClassB :-
        map-class-cstr.dep-arrow M ClassAM ClassBM,
        map-class-cstr.dep-arrow N ClassAN ClassBN,
        param-class.union ClassAM {param-class-cstr.negate ClassAN} ClassA,
        param-class.union ClassBM {param-class-cstr.negate ClassBN} ClassB.

    pred requires-axiom -> param-class.
    requires-axiom (pc M N) :- (map-class-cstr.geq M map2b ; map-class-cstr.geq N map2b).
    pred doesnt-require-axiom -> param-class.
    doesnt-require-axiom (pc M N) :- map-class-cstr.geq map2a M, map-class-cstr.geq map2a N.

    pred all -> param-class.
    all (pc M N) :- map-class-cstr.all M, map-class-cstr.all N.

    func certain param-class ->.
    certain uvar :- !, fail.
    certain (pc uvar _) :- !, fail.
    certain (pc _ uvar) :- !, fail.
    certain _.
}

func aterm.certain aterm ->.
%XXX We should expand that with checking the gref
% and with checking wether we have multiple copies of the gref in the database.
aterm.certain T :- aterm.util.all-classes T L, std.forall L param-class-cstr.certain.

pred has-funext-if-needed -> param-class.
has-funext-if-needed C :-
    if (trocq.db.funext _)
    (param-class-cstr.all C)
    (param-class-cstr.doesnt-require-axiom C).
pred has-univ-if-needed -> param-class.
has-univ-if-needed C :-
    if (trocq.db.univalence _)
    (param-class-cstr.all C)
    (param-class-cstr.doesnt-require-axiom C).

pred solve-gref-constraint i:cstr.
solve-gref-constraint (cstr-gref G AT T' TR) :- !,
    logging.trace (coq.say "[solve-gref]" G AT T' TR),
    trocq.db.gref G AT' G' GR,
    aterm.util.equals-ignore AT' AT,
    logging.trace (coq.say "[found-gref]" G AT' G' GR),
    coq.env.global G' T',
    coq.env.global GR TR.

func cstr->prop cstr -> prop.
cstr->prop (cstr-eq X Y) (X = Y).
cstr->prop (cstr-pi C CA CB) (has-funext-if-needed C, param-class-cstr.dep-pi C CA CB).
cstr->prop (cstr-arrow C CA CB) (has-funext-if-needed C, param-class-cstr.dep-arrow C CA CB).
cstr->prop (cstr-type C CR) (
    (param-class-cstr.doesnt-require-axiom C, param-class-cstr.all CR) ;
    (trocq.db.univalence _, param-class-cstr.all C, CR = (pc map4 map4))
).
cstr->prop (cstr-geq CA CB) (param-class-cstr.geq CA CB).
cstr->prop (cstr-gref _ _ _ _ as Cstr) (solve-gref-constraint Cstr).

func cstr->varz cstr -> list param-class.
cstr->varz (cstr-eq X Y) [X,Y].
cstr->varz (cstr-pi X Y Z) [X,Y,Z].
cstr->varz (cstr-arrow X Y Z) [X,Y,Z].
cstr->varz (cstr-type X Y) [X,Y].
cstr->varz (cstr-geq X Y) [X,Y].
cstr->varz (cstr-gref _ T _ _) L :- aterm.util.all-classes T L.

func param-class.pp param-class -> string.
param-class.pp (uvar as X) S :- term_to_string X S, !.
param-class.pp (pc N M) S :- (var N; var M), !, 
    S is "(" ^ {term_to_string N} ^ "," ^ {term_to_string M} ^ ")".
param-class.pp C S :- 
    param-class.to_string C S.

func cstr.pp cstr -> string.
cstr.pp (cstr-eq X Y) S :- S is {param-class.pp X} ^ "=" ^ {param-class.pp Y}.
cstr.pp (cstr-pi X Y Z) S :- S is "DΠ(" ^ {param-class.pp X} ^ ") = (" ^ {param-class.pp Y} ^ "," ^ {param-class.pp Z} ^ ")".
cstr.pp (cstr-arrow X Y Z) S :- S is "D➜(" ^ {param-class.pp X} ^ ") = (" ^ {param-class.pp Y} ^ "," ^ {param-class.pp Z} ^ ")".
cstr.pp (cstr-type X Y) S :- S is "D□(" ^ {param-class.pp X} ^ "," ^ {param-class.pp Y} ^ ")".
cstr.pp (cstr-geq X Y) S :- S is {param-class.pp X} ^ " ⩾ " ^ {param-class.pp Y}.
cstr.pp (cstr-gref G T G' RG) S :- S is {term_to_string G} ^ " @ " ^ {term_to_string T} ^ " ~ " ^ {term_to_string G'} ^ " ∵ " ^ {term_to_string RG}.

func cstrs.pp list cstr -> string.
cstrs.pp L S :- std.string.concat "\n" {std.map L cstr.pp} S.

func cstrs->evars list cstr -> list param-class.
cstrs->evars [] [].
cstrs->evars [Cstr|Cstrz] L :-
    cstrs->evars Cstrz L0,
    cstr->varz Cstr LC,
    util.append-uniq-evar L0 LC L, !.

func add-cstr cstr-list, cstr -> cstr-list.
add-cstr _ C _ :- logging.trace (coq.say "[cstr] Adding constraint" {cstr.pp C}), fail, !.
add-cstr L C [C|L]. 

func is-deterministic cstr -> bool.
is-deterministic (cstr-eq _ _) tt:- !.
is-deterministic (cstr-pi C _ _) tt :- param-class-cstr.certain C, !.
is-deterministic (cstr-arrow C _ _) tt :- param-class-cstr.certain C, !.
is-deterministic (cstr-type C CR) tt :- 
    param-class-cstr.certain C, param-class-cstr.certain CR, !.
is-deterministic (cstr-geq CA CB) tt :-
    param-class-cstr.certain CA, param-class-cstr.certain CB, !.
%XXX We should add constraints for certainty on G' and about what is in the database
is-deterministic (cstr-gref _ AT _ _) tt :- aterm.certain AT, !. 
is-deterministic _ ff.

pred do-or i:prop i:prop.
do-or P _ :- P.
do-or _ Q :- !, Q, fail.

pred do-cstrz cstr-list.
do-cstrz [].
do-cstrz [Cstr|Cstrz] :-
    cstr->prop Cstr P, !,
    do-or P (logging.trace (coq.say "[cstr] Failed constraint" {cstr.pp Cstr})),
    do-cstrz Cstrz.

% Solves deterministically as many constraints as possible.
% Returns the ones that could not be solved
func deterministic-progress cstr-list -> cstr-list.
deterministic-progress [] [] :- !.
deterministic-progress Cstrs OutCstrs:-
    std.partition Cstrs (c\ is-deterministic c tt) DeterministicCstrs NonDeterministicCstrs,
    if (DeterministicCstrs = [])
    (OutCstrs = NonDeterministicCstrs) % We cannot go further deterministically
    (
        logging.trace (coq.say "[cstr]" "Deterministic" {std.map DeterministicCstrs cstr.pp}),
        do-cstrz DeterministicCstrs, !,
        deterministic-progress NonDeterministicCstrs OutCstrs
    ).

func undeterministic-progress cstr-list.
undeterministic-progress [] :- !.
undeterministic-progress Cstrz :-
    deterministic-progress Cstrz Cstrz',
    if (Cstrz' = [Cstr0|CstrzOther])
    (
        logging.trace (coq.say "[cstr]" "Solving" {cstr.pp Cstr0} "non-determinstically"),
        !,
        do-cstrz [Cstr0], % Non-deterministically
        logging.trace (coq.say "[cstr]" "Solved to" {cstr.pp Cstr0}), 
        undeterministic-progress CstrzOther,
        !
    ) (true),
    !.

pred solve-constraints i:cstr-list.
solve-constraints L :-
    std.findall (trocq.db.gref _ _ _ _) DatabaseContents,
    logging.trace (coq.say "[solve-constraints] Gref Database :" DatabaseContents),
    logging.trace (coq.say "[solve-constraints] Solving constraints", coq.say {cstrs.pp L}), !,
    cstrs->evars L LVars,
    logging.trace (coq.say "[solve-constraints] Variables are" LVars),
    (undeterministic-progress L; trocq.error "Could not solve constraint graph"), !,
    logging.trace (coq.say "[solve-constraints] Solved all constraints ! Assignation is " LVars).
