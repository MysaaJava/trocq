% -----------------------------------------------------------------------------
% parametricity translation
% -----------------------------------------------------------------------------

accumulate "Trocq.Elpi/annot".
accumulate "Trocq.Elpi/data".

macro @pi-adecl N PAD_AT PAD_F :-
  aterm.triple PAD_AT PAD_T PAD_T' PAD_TR,
  util.mk-app PAD_TR [PAD_T,PAD_T'] PAD_TRx,
  coq.name-suffix N "'" N',
  coq.name-suffix N "R" NR,
  @pi-decl N PAD_T x\ (
  @pi-decl N' PAD_T' x'\ (
  @pi-decl NR PAD_TRx xR\ (
  pi ax\ [
    adecl ax N x x' xR PAD_AT
  ] => (
    logging.trace (coq.say "[adecl]" ax "==" x "@" PAD_AT "~" x' "∵" xR),
    (PAD_F ax x x' xR)
  )))).

% param X T X' XR translates X at annotated type T, to X' with witness XR
pred param i:aterm, i:aterm, o:term, o:term o:cstr-list.

% TrocqConv + TrocqConst
param Tm AT' Tm' Witness Cstrs' :- aterm.util.global Tm GTm, !, std.do! [
  logging.debug (coq.say "[param] Rule const :" Tm "@" AT'),
  annot.typecheck Tm AT CstrsTypecheck,
  annot.sub-type AT AT' CstrsSubtype,
  std.append CstrsTypecheck CstrsSubtype Cstrs,
  add-cstr Cstrs (cstr-gref GTm AT Tm' TRR) Cstrs', % Can't we do the weakening in the constraint resolution ?
  annot.weaken AT AT' {aterm.erase Tm} Tm' TRR Witness,
  logging.debug (coq.say "[param] Out rule const :" Tm' "∵" Witness)
].

% TrocqConv + TrocqVar
param X T2 X' Witness Cstrs :- name X, !,
  logging.debug (coq.say "[param] Rule var :" X "@" T2),
  adecl X _ _ X' XR T1, !,
  annot.sub-type T1 T2 Cstrs, !,
  annot.weaken T1 T2 {aterm.erase X} X' XR Witness,
  logging.debug (coq.say "[param] Out rule var :" X' "∵" Witness).

% TrocqSort
% TODO: This will fail if we don't have the same sort before and after ~
% We should add a unify-eq between S and S'
param
  (asort S CR as T)
  (asort _ C as AT)
  (sort S' as T')
  RT Cstrs :- !, std.do! [
    logging.debug (coq.say "[param] Rule sort :" T "@" AT),
    add-cstr [] (cstr-type C CR) Cstrs,
    trocq.data.ttype C CR RT,
    coq.unify-eq (sort S) (sort S') ok,
    logging.debug (coq.say "[param] Out rule sort :" T' "∵" RT),
  ].

% TrocqLam
param (afun N T F as T0) (aprod _ TT FT as AT) (fun N' T' F' as T0') Witness Cstrs :- !,
  logging.debug (coq.say "[param] Rule lam :" T0 "@" AT),
  coq.name-suffix N "'" N', 
  coq.name-suffix N "R" NR,
  aterm.triple T Ter T' TR,
  annot.eq T TT CstrsT,
  (@pi-adecl N T (ax\ x\ x'\ xR\ 
    param (F ax) (FT ax) (F' x') (FR x x' xR) CstrsF
  )),
  std.append CstrsT CstrsF Cstrs,
  Witness = (
    fun N Ter x\
    fun N' T' x'\
    fun NR (app [TR, x, x']) xR\
      FR x x' xR
  ),
  logging.debug (coq.say "[param] Out rule lam :" T0' "∵" Witness).

% TrocqArrow
param
  (aprod _ A (_\ B ) as T) (asort Sort C as AT)
  (prod `_` A' (_\ B') as T') Witness Cstrs' :- !,
   std.do! [
      logging.debug (coq.say "[param] Rule arrow :" T "@" AT),
      (annot.typecheck A (asort SortA _) CstrsT; trocq.error "[param/arrow] Cannot typecheck" A "with a sort"),
      param A (asort SortA CA) A' AR CstrsA,
      param B (asort Sort CB) B' BR CstrsB,
      std.flatten [CstrsT,CstrsA,CstrsB] Cstrs,
      add-cstr Cstrs (cstr-arrow C CA CB) Cstrs',
      coq.mk-app {trocq.data.arrow C} [{aterm.erase A}, A', AR, {aterm.erase B}, B', BR] Witness,
      logging.debug (coq.say "[param] Out rule arrow :" T' "∵" Witness)
    ].

% TrocqPi
param
  (aprod N A B as T) (asort Sort C as AT)
  (prod N' A' B' as T')
  Witness Cstrs' :- !, std.do![
    logging.debug (coq.say "[param] Rule pi :" T "@" AT),
    coq.name-suffix N "'" N',
    coq.name-suffix N "R" NR,
    (annot.typecheck A (asort SortA _) CstrsD; trocq.error "[param/forall] Cannot typecheck" A "with a sort"),
    param A (asort SortA CA) A' AR CstrsA,
    (@pi-adecl N A (ax\ x\ x'\ xR\
      param (B ax) (asort Sort CB) (B' x') (BR x x' xR) CstrsB
    )),
    std.flatten [CstrsD,CstrsA,CstrsB] Cstrs,
    add-cstr Cstrs (cstr-pi C CA CB) Cstrs',
    coq.mk-app {trocq.data.forall C}
      [ {aterm.erase A}, A', AR,
        fun N {aterm.erase A} {aterm.util.erase-fun N A B},
        fun N' A' B',
        fun N {aterm.erase A} a\
         fun N' A' a'\
         fun NR (app [{trocq.data.r CA}, {aterm.erase A}, A', AR, a, a']) aR\
          BR a a' aR
      ] Witness,
    logging.debug (coq.say "[param] Out rule pi :" T' "∵" Witness)
  ].

% TrocqConv for F (argument B in param.args) + TrocqApp
param (aapp [F|Xs] as T) B (app [F'|Xs'] as T') Witness Cstrz :- !, std.do! [
  logging.debug (coq.say "[param] Rule app :" T "@" B),
  annot.typecheck F TF CstrsT,
  param F TF F' FR Cstrs0,
  param.args TF B Xs Xs' XsR B0 CstrzP,
  std.flatten [CstrsT, Cstrs0, CstrzP] Cstrz,
  coq.mk-app FR XsR AppR,
  annot.weaken B0 B {aterm.erase T} T' AppR Witness,
  logging.debug (coq.say "[param] Out rule app :" T' "∵" Witness)
].

pred param.args i:aterm, o:aterm, i:list aterm, o:list term, o:list term, o:aterm, o:cstr-list.
param.args B0 B [] [] [] B0 Cstrs :- std.do! [
  annot.sub-type B0 B Cstrs].
param.args (aprod _ T Bk) B [X|Xs] [X'|Xs'] [X_T, X', XR|XRs] B0 Cstrs :- !,
  param X T X' XR CstrsX, !,
  param.args (Bk X) B Xs Xs' XRs B0 CstrsB,
  std.append CstrsX CstrsB Cstrs,
  aterm.erase X X_T.

param.args FunTy AB L _ _ _ _ :-
  trocq.error "[param.args] unsupported combination:" FunTy "&" AB "&" L.

param X T X' Witness _ :-
  trocq.error "[param] unsupported combination:" X "@" T "~" X' "∵" Witness.

